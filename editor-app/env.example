# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth
NEXTAUTH_SECRET=your_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# Security
ALLOWED_EMAILS=user1@example.com,user2@example.com

# GitHub API (Server-side)
GITHUB_TOKEN=your_github_pat
# リポジトリの実オーナー。旧値(hikagon0601)は個人アカウントの名残で、
# NEXT_PUBLIC_GITHUB_OWNER (qumiclub) と食い違っていた。本番のVercel環境変数も
# qumiclub になっているか要確認。
GITHUB_OWNER=qumiclub
GITHUB_REPO=club-welcome-page

# GitHub (Client-side, for image preview)
NEXT_PUBLIC_GITHUB_OWNER=qumiclub
NEXT_PUBLIC_GITHUB_REPO=club-welcome-page

